# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google Gemini (preferred if set) — from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# Optional model override (default tries flash-lite, then 1.5-flash, then 2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash-lite

# App URL for OAuth redirects (production: https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" for local preview without Supabase/Anthropic keys
# Set to "false" when using real Google sign-in
NEXT_PUBLIC_DEMO_MODE=true

# Server-only — never expose to the browser (Settings > API > Secret key, sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_key

# ─── Google OAuth (Supabase Dashboard) ─────────────────────────────────────
# 1. Supabase > Authentication > Providers > Google → Enable
# 2. Create OAuth credentials at https://console.cloud.google.com
# 3. Supabase > Authentication > URL Configuration:
#      Site URL: http://localhost:3000
#      Redirect URLs: http://localhost:3000/auth/callback
# 4. Run supabase/schema.sql in SQL Editor (includes user_profiles + RLS)
